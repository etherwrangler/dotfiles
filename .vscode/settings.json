{
    "json.schemaDownload.trustedDomains": {
        "https://github.com/fastfetch-cli/fastfetch/": true
    },
    "Lua.diagnostics.disable": [
        "different-requires"
    ],
    "zshellcheck.filePatterns": [
        "**/*.zsh",
        "**/*.zsh-theme",
        "**/*.zshrc",
        "**/*.zshenv",
        "**/*.zprofile",
        "**/*.zlogin",
        "**/*.zlogout",
        "**/zshrc",
        "**/zshenv",
        "**/zprofile",
        "**/zlogin",
        "**/zlogout",
        "**/dot_zshrc",
        "**/dot_zprofile"
    ],
    "shellcheck.ignorePatterns": {
        "**/dot_zshrc": true,
        "**/dot_zprofile": true
    }
}
