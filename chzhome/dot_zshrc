: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_STATE_HOME:=$HOME/.local/state}"
export XDG_CONFIG_HOME XDG_CACHE_HOME XDG_DATA_HOME XDG_STATE_HOME

source_zsh_config() {
  local file="$XDG_CONFIG_HOME/zsh/$1"
  [[ -r "$file" ]] && source "$file"
}

source_zsh_config history.zsh
source_zsh_config options.zsh
source_zsh_config aliases.zsh
source_zsh_config bindings.zsh
source_zsh_config ls-colors.zsh
source_zsh_config completion.zsh
source_zsh_config plugins.zsh

# Setup Homebrew environment settings for MacOS
if [[ -f "/opt/homebrew/bin/brew" ]] then
  eval "$(/opt/homebrew/bin/brew shellenv)" # noka: ZC1046, ZC1098
fi

# Add Starship
eval "$(starship init zsh)" # noka: ZC1046, ZC1098

