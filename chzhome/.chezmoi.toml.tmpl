{{/* boolean feature tags */}}
{{$ephemeral := false -}}{{/* true if this machine is ephemeral, e.g. a cloud or VM instance */}}
{{$headless := false -}}{{/* true if this machine does not have a screen and keyboard */}}
{{$devtools := false -}}{{/* true if this machine should have development tools */}}
{{$games := false -}}{{/* true if this machine should have games */}}
{{$ittools := false -}}{{/* true if this machine should have IT and network tools */}}
{{$work := false -}}{{/* true if this machine is a work machine */}}
{{$installwsl := false -}}{{/* true if Windows should install WSL and Ubuntu */}}
{{$nopackages := false -}}{{/* true if this machine should not install any packages */}}
{{$personal := false -}}{{/* true if this machine should have personal secrets */}}
{{$sshKeys := false -}}{{/* true if this machine should generate per-device SSH keys */}}
{{$sshSecrets := false -}}{{/* true if this machine should restore encrypted SSH config snippets */}}

{{/* detect if linux and then add the distro the osid variable */}}
{{- $osid := .chezmoi.os -}}
{{- if (and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id")) -}}
{{-   $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{/* detect GitHub codespaces, VSCode remote containers, Docker containers, Multipass VMs, and Vagrant boxes */}}
{{- if or (env "CODESPACES") (env "REMOTE_CONTAINERS_IPC") (eq .chezmoi.username "root" "ubuntu" "vagrant" "vscode") -}}
{{-   $ephemeral = true -}}
{{-   $headless = true -}}
{{- end -}}

{{- if not (or ($ephemeral) ($headless) ) }}
{{- $sshKeys = promptBoolOnce . "sshKeys" "Generate SSH keys" -}}
{{- $sshSecrets = promptBoolOnce . "sshSecrets" "Restore encrypted SSH config files" -}}
{{- $nopackages = promptBoolOnce . "nopackages" "Block package installation" -}}
{{- if not $nopackages -}} 
{{-     $devtools = promptBoolOnce . "devtools" "Install Development Tools" -}}
{{-     $games = promptBoolOnce . "games" "Install Games" -}}
{{-     $ittools = promptBoolOnce . "ittools" "Install IT and Network Tools" -}}
{{-     $personal = promptBoolOnce . "personal" "Install Personal Software and Secrets" -}}
{{-     $work = promptBoolOnce . "work" "Install Work Software and Secrets" -}}
{{-     if eq .chezmoi.os "windows" -}}
{{-         $installwsl = promptBoolOnce . "installwsl" "Install Windows Subsystem for Linux (WSL) and Ubuntu" -}}
{{-     end -}}
{{- end -}}
{{- end -}}

encryption = "age"

[age]
    identity = "~/.config/chezmoi/key.txt"
    recipient = "age1jtuczhvm3fxtlvchkz9cuknslydkz4nltwl623nwlfk33nkza9ps385kuu"

[data]
    devtools = {{ $devtools }}
    ephemeral = {{ $ephemeral }}
    games = {{ $games }}
    headless = {{ $headless }}
    installwsl = {{ $installwsl }}
    ittools = {{ $ittools }}
    nopackages = {{ $nopackages }}
    osid = {{ $osid | quote }}
    personal = {{ $personal }}
    sshKeys = {{ $sshKeys }}
    sshSecrets = {{ $sshSecrets }}
    work = {{ $work }}
