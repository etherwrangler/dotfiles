# Files to never copy to home directory
README.md
.vscode/
.vscode/**

# Files to ignore if not on MacOS
{{ if ne .chezmoi.os "darwin" }}
.chezmoiscripts/darwin/**
.chezmoidata/darwin-packages.yaml
{{ end }}

# Files to ignore on Windows
{{ if ne .chezmoi.os "windows" }}
.chezmoiscripts/windows/**
.chezmoidata/windows-packages.yaml
Documents
{{ else }}
.config/*
!.config/starship.toml
.zshrc
{{ end }}

# Files to ignore if not on Linux
{{ if ne .chezmoi.os "linux" }}
.chezmoiscripts/linux/**
.chezmoidata/linux-packages.yaml
{{ end }}

# Files to ignore unless Debian package installation is enabled
{{ if not (and (eq .osid "linux-debian") (not .nopackages)) }}
.local/bin/nvim
{{ end }}

# Files to ignore on headless systems
{{ if .headless }}
.config/wezterm
{{ end }}
