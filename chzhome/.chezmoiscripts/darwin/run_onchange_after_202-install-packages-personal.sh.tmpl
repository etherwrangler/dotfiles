#!/bin/sh

set -eu

{{ if and (not .nopackages) (get . "personal") -}}

brew bundle --file=/dev/stdin <<EOF
{{ range (.packages.darwin.homebrew.personal.brews | default (list) | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
{{ range (.packages.darwin.homebrew.personal.casks | default (list) | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end -}}
EOF

{{ end -}}
