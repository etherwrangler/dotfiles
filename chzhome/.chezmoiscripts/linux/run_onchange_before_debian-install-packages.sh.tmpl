{{ if and (eq .osid "linux-debian") (not .nopackages) -}}

{{ $packages := list
    "curl"
    "git"
    "jq"
    "tealdeer"
    "starship"
    "zsh" -}}

{{ $sudo := "sudo" -}}
{{ if eq .chezmoi.username "root" -}}
{{   $sudo = "" -}}
{{ end -}}

#!/bin/bash

set -eufo pipefail

{{ $sudo }} apt update
{{ $sudo }} apt install {{ $packages | join " " }}

zsh_path="$(command -v zsh)"
if [ "${SHELL:-}" != "$zsh_path" ]; then
    chsh -s "$zsh_path"
fi

nvim_latest_version="$(
    curl -fsSL https://api.github.com/repos/neovim/neovim/releases/latest \
        | jq -r '.tag_name'
)"
nvim_current_version=""
nvim_bin="/opt/nvim-linux-x86_64/bin/nvim"
if [ ! -x "$nvim_bin" ] && command -v nvim >/dev/null 2>&1; then
    nvim_bin="$(command -v nvim)"
fi
if [ -x "$nvim_bin" ]; then
    nvim_current_version="$("$nvim_bin" --version | sed -n '1s/^NVIM //p')"
fi

if [ "$nvim_current_version" != "$nvim_latest_version" ]; then
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "$tmpdir"' EXIT

    curl -fL \
        -o "$tmpdir/nvim-linux-x86_64.tar.gz" \
        https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz
    {{ $sudo }} rm -rf /opt/nvim-linux-x86_64
    {{ $sudo }} tar -C /opt -xzf "$tmpdir/nvim-linux-x86_64.tar.gz"
fi

{{ end -}}
